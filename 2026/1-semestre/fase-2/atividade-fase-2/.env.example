# Copy this file to .env and fill in your credentials
# cp .env.example .env
#
# Two supported modes:
#
# MODE A — Azure SQL (credentials embedded in URL, recommended):
#   Set DB_URL with user= and password= in the connection string.
#   DB_USER and DB_PASSWORD are NOT required in this mode.
#
# MODE B — Local SQL Server (docker-compose.local.yml):
#   DB_URL has no embedded credentials.
#   DB_USER and DB_PASSWORD are required separately.

# ── Azure SQL connection string (Mode A) ───────────────────────────────────
# Include user= and password= directly in the URL:
DB_URL=jdbc:sqlserver://SEU_SERVIDOR.database.windows.net:1433;database=agnello;user=SEU_USUARIO@SEU_SERVIDOR;password=SUA_SENHA;encrypt=true;trustServerCertificate=false;hostNameInCertificate=*.database.windows.net;loginTimeout=30;

# ── Separate credentials (Mode B — only needed for local SQL Server) ───────
DB_USER=
DB_PASSWORD=
